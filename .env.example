# Environment Variables for Mansão Maromba Distribution Radar

# Notion Integration - Option 1: Direct Token (Simple)
NOTION_TOKEN=your_notion_integration_token_here

# Notion OAuth - Option 2: OAuth 2.0 Flow (Recommended for production)
# Get these from: https://www.notion.so/my-integrations
OAUTH_CLIENT_ID=your_oauth_client_id_here
OAUTH_CLIENT_SECRET=your_oauth_client_secret_here
OAUTH_REDIRECT_URI=http://localhost:3000/oauth-callback

# Notion Parent Page ID (for creating new databases)
PARENT_PAGE_ID=your_parent_page_id_here

# Google Places API (for bar prospecting)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Notion Database IDs
PROSPECT_DB_ID=your_alvos_de_prospeccao_database_id_here
MAP_DB_ID=your_mapa_de_distribuicao_database_id_here
BACKLOG_DB_ID=your_backlog_database_id_here

# Instructions:
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. Never commit .env to version control
